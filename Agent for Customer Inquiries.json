    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  let raw;\n\n  if (item.json.output_text) {\n    raw = item.json.output_text;\n  } else if (item.json.text) {\n    raw = item.json.text;\n  } else if (item.json.output?.[0]?.content?.[0]?.text) {\n    raw = item.json.output[0].content[0].text;\n  } else {\n    throw new Error(\"No model output found\");\n  }\n\n  const cleaned = raw\n    .replace(/```json/gi, '')\n    .replace(/```/g, '')\n    .trim();\n\n  let data;\n  try {\n    data = JSON.parse(cleaned);\n  } catch (e) {\n    throw new Error(\"Invalid JSON from model: \" + cleaned);\n  }\n\n  // 🔥 SAFE STRUCTURE (THIS FIXES FALLBACK)\n  return {\n    json: {\n      ...item.json,\n\n      classification: {\n        category: data.category ?? null,\n        priority: data.priority ?? null,\n        confidence: data.confidence ?? null\n      },\n\n      enrichment: {\n        core_issue: data.core_issue ?? \"\",\n        entities: data.entities ?? {},\n        urgency: data.urgency ?? \"Low\",\n        summary: data.summary ?? \"\"\n      }\n    }\n  };\n});"
      },
