      "parameters": {
        "jsCode": "return items.map(item => {\n  const classification = item.json.classification ?? item.json ?? {};\n  const enrichment = item.json.enrichment ?? {};\n\n  const message =\n    item.json.original_message ??\n    item.json.message ??\n    \"\";\n\n  const category =\n    classification.category ??\n    item.json.category ??\n    null;\n\n  const priority =\n    classification.priority ??\n    item.json.priority ??\n    null;\n\n  const confidence =\n    classification.confidence ??\n    item.json.confidence ??\n    null;\n\n  const urgency =\n    enrichment.urgency ??\n    item.json.urgency ??\n    \"Low\";\n\n  const core_issue =\n    enrichment.core_issue ??\n    item.json.core_issue ??\n    \"Unclear issue — requires human review\";\n\n  const summary =\n    enrichment.summary ??\n    item.json.summary ??\n    \"The message requires human review due to insufficient clarity.\";\n\n  const entities =\n    enrichment.entities ??\n    item.json.entities ??\n    {};\n\n  // 🔹 ESCALATION (UNCHANGED)\n  const escalationKeywords = [\n    \"outage\",\"system down\",\"down for all users\",\"down for everyone\",\n    \"service unavailable\",\"cannot access\",\"can't access\",\n    \"login failure\",\"cannot login\",\"can't login\",\"login issue\",\n    \"data loss\",\"lost data\",\n    \"security issue\",\"security breach\",\"unauthorized access\",\"hacked\",\n    \"urgent\",\"asap\",\"immediately\",\"blocking\",\"production issue\",\"critical\",\n    \"billing error\",\"overcharged\",\"charged twice\",\"incorrect charge\"\n  ];\n\n  const keywordEscalation = escalationKeywords.some(k =>\n    message.toLowerCase().includes(k)\n  );\n\n  const escalation =\n    priority === \"High\" ||\n    urgency === \"High\" ||\n    keywordEscalation;\n\n  // 🔹 QUEUE (KEEP ORIGINAL)\n  const queue =\n    item.json.queue ?? \"Customer Success\";\n\n  let finalQueue =\n    item.json.final_queue ?? queue;\n\n  if (escalation && !item.json.fallback) {\n    finalQueue = \"Escalation Queue\";\n  }\n\n  // 🔥 FIX: ensure handled_by is NEVER empty\n  const handled_by =\n    item.json.handled_by ??\n    (queue === \"Engineering\" ? \"Engineering Team\" :\n     queue === \"Billing\" ? \"Billing Team\" :\n     queue === \"Product\" ? \"Product Team\" :\n     queue === \"IT\" ? \"IT Team\" :\n     queue === \"Fallback\" ? \"Human Review Team\" :\n     \"Customer Success Team\");\n\n  return {\n    json: {\n      message,\n\n      category,\n      priority,\n      confidence,\n\n      core_issue,\n      entities,\n      urgency,\n      summary,\n\n      queue,\n      handled_by,\n\n      fallback: item.json.fallback ?? false,\n      escalation,\n\n      final_queue: finalQueue\n    }\n  };\n});"
      },
